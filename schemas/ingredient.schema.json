{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lazy-kitchen.local/schemas/ingredient.schema.json",
  "title": "Ingredient",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "category", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ING-[A-Z0-9-]+$"
    },
    "name": { "$ref": "_common.schema.json#/$defs/bilingualName" },
    "aliases": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "zh": { "type": "array", "items": { "type": "string" } },
        "en": { "type": "array", "items": { "type": "string" } }
      }
    },
    "category": {
      "type": "string",
      "enum": [
        "protein-meat", "protein-poultry", "protein-seafood", "protein-egg",
        "protein-soy", "protein-legume",
        "vegetable-leafy", "vegetable-root", "vegetable-fruit", "vegetable-allium",
        "vegetable-mushroom", "vegetable-other",
        "fresh-aromatic", "fruit",
        "grain-rice", "grain-noodle", "grain-flour", "grain-other",
        "dairy", "fat-oil",
        "whole-spice", "ground-spice", "dried-umami", "condiment-base"
      ]
    },
    "season": { "$ref": "_common.schema.json#/$defs/season" },
    "storage_profile": { "type": "string" },
    "diet_tags": {
      "type": "array",
      "items": { "$ref": "_common.schema.json#/$defs/diet_tag" }
    },
    "procurement_mode": { "$ref": "_common.schema.json#/$defs/procurementMode" },
    "cn_market_pre_prepped": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Common pre-prepped forms available on Chinese fresh-food e-commerce (e.g. 排骨切块)"
    },
    "buying_notes": { "$ref": "_common.schema.json#/$defs/bilingualText" },
    "mvp_level": {
      "type": "string",
      "enum": ["core", "common", "uncommon", "specialty"]
    },
    "status": { "$ref": "_common.schema.json#/$defs/status" }
  }
}
