{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lazy-kitchen.local/schemas/ratio.schema.json",
  "title": "Ratio (flavor formula / mother sauce)",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "ratio", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^RATIO-(MOTHER-)?[A-Z0-9-]+-v\\d+$"
    },
    "name": { "$ref": "_common.schema.json#/$defs/bilingualName" },
    "is_mother": {
      "type": "boolean",
      "description": "True for mother sauces (béchamel, velouté, etc.) and CN-BRAISE"
    },
    "parent": {
      "type": ["string", "null"],
      "description": "Parent RATIO id this descends from",
      "pattern": "^RATIO-[A-Z0-9-]+-v\\d+$"
    },
    "daughters": {
      "type": "array",
      "items": { "type": "string", "pattern": "^RATIO-[A-Z0-9-]+-v\\d+$" }
    },
    "ratio": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formula"],
      "properties": {
        "formula": {
          "type": "string",
          "description": "Human-readable formula, e.g. '1:1:1 醋:酱油:水'"
        },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["item", "parts"],
            "properties": {
              "item": { "$ref": "_common.schema.json#/$defs/bilingualName" },
              "parts": { "type": "number" },
              "notes": { "type": "string" }
            }
          }
        }
      }
    },
    "cuisine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "region": { "type": "string" },
        "country": { "type": "string" }
      }
    },
    "use_with": {
      "type": "array",
      "items": { "$ref": "_common.schema.json#/$defs/bilingualText" }
    },
    "notes": { "$ref": "_common.schema.json#/$defs/bilingualText" },
    "status": { "$ref": "_common.schema.json#/$defs/status" },
    "cross_reviewed": { "type": "boolean" },
    "cross_reviewer_cli": { "type": "string" },
    "cross_reviewer_model": { "type": "string" },
    "cross_review_at": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "approved" } }, "required": ["status"] },
      "then": { "required": ["cross_reviewed"], "properties": { "cross_reviewed": { "const": true } } }
    }
  ]
}
