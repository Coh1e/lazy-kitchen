{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lazy-kitchen.local/schemas/sop.schema.json",
  "title": "SOP (Standard Operating Procedure)",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "category", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^SOP-[A-Z0-9-]+$"
    },
    "name": { "$ref": "_common.schema.json#/$defs/bilingualName" },
    "category": {
      "type": "string",
      "description": "Logical grouping for navigation",
      "enum": [
        "prep", "blanch", "stew", "braise", "stir-fry", "deep-fry", "pan-sear",
        "grill", "roast", "steam", "soup-noodle", "cooked-base",
        "cut", "marinate", "clean",
        "vacuum-dry", "vacuum-liquid", "labeling", "reheat",
        "optimize", "compose", "regional"
      ]
    },
    "heat_type": { "$ref": "_common.schema.json#/$defs/heatType" },
    "cooking_method": { "$ref": "_common.schema.json#/$defs/cookingMethod" },
    "station": { "$ref": "_common.schema.json#/$defs/station" },
    "time_tier": { "$ref": "_common.schema.json#/$defs/timeTier" },
    "heat_level_used": { "$ref": "_common.schema.json#/$defs/heatLevel" },
    "cut_required": {
      "type": "array",
      "items": { "type": "string", "pattern": "^SOP-CUT-[A-Z0-9-]+$" }
    },
    "equipment_required": {
      "type": "array",
      "items": { "type": "string" }
    },
    "optional_if_pre_prepped": { "type": "boolean" },
    "hardware": {
      "type": "array",
      "items": { "type": "string" }
    },
    "steps": { "$ref": "_common.schema.json#/$defs/bilingualText" },
    "tips": { "$ref": "_common.schema.json#/$defs/bilingualText" },
    "status": { "$ref": "_common.schema.json#/$defs/status" },
    "cross_reviewed": { "type": "boolean" },
    "cross_reviewer_cli": { "type": "string" },
    "cross_reviewer_model": { "type": "string" },
    "cross_review_at": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "approved" } }, "required": ["status"] },
      "then": { "required": ["cross_reviewed"], "properties": { "cross_reviewed": { "const": true } } }
    }
  ]
}
