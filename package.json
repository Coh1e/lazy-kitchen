{
  "name": "lazy-kitchen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "懒蛋厨房 / Lazy Kitchen — modular world-cuisine kitchen OS. Make Kitchen Great Again!",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "validate": "tsx scripts/validate-data.ts",
    "lint:bilingual": "tsx scripts/lint-bilingual.ts",
    "build:glossary": "tsx scripts/build-glossary.ts",
    "test": "npm run test:unit && npm run test:e2e && npm run test:visual",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test --project=e2e-desktop",
    "test:visual": "playwright test --project=visual-desktop --project=visual-mobile",
    "test:visual:update": "playwright test --project=visual-desktop --project=visual-mobile --update-snapshots",
    "test:watch": "vitest",
    "all": "npm run validate && npm run lint:bilingual && npm run build:glossary && npm run build && npm run test"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.3.0",
    "@playwright/test": "^1.59.1",
    "@rollup/plugin-yaml": "^4.1.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3": "^7.4.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "jsdom": "^29.0.2",
    "marked": "^14.1.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "d3": "^7.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  }
}
