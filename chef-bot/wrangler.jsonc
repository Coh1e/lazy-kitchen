{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lazy-kitchen-chef-bot",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-26",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  // Allow `import x from '*.md'` to bundle markdown files as strings.
  // Used by src/personas-bundle.ts to inline persona prompts at deploy.
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.md"],
      "fallthrough": true
    }
  ]
}
